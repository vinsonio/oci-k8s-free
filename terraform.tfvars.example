# Example Terraform Variables
# ⚠️  EXAMPLE ONLY - Replace with your actual values
# See README.md Step 1 for how to obtain these values

region                      = "us-phoenix-1"
region_identifier           = "PHX"  # Short identifier (PHX, ASH, FRA, etc.) for Service Gateway
compartment_ocid            = "ocid1.compartment.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
kubernetes_version          = "v1.34.2"
cluster_name                = "cluster1"
image_id                    = "ocid1.image.oc1.xxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Security settings
kubernetes_api_public_enabled = false
# allowed_k8s_api_cidrs = ["203.0.113.0/24"]  # Uncomment to allow specific IPs

# ⚠️  IMPORTANT: When kubernetes_api_public_enabled = false
# You MUST have a way to access the private API endpoint to use kubectl:
#   Option 1: OCI Bastion Service (below) - free, easiest for getting started
#   Option 2: Site-to-Site VPN (below) - free, secure, requires on-prem VPN equipment
#   Option 3: Temporarily set kubernetes_api_public_enabled = true

# OCI Bastion Service (for private API access from anywhere)
create_bastion = false  # Set to true to create OCI Bastion Service (Always Free)
# bastion_client_cidr_allow_list = ["203.0.113.0/32"]  # Restrict to your IP for security (optional)

# Site-to-Site VPN (for private API access from your office/on-premises)
create_vpn = false  # Set to true if you have a VPN endpoint
# cpe_ip_address = "203.0.113.100"        # Your VPN endpoint public IP (required if create_vpn = true)
# customer_network_cidr = "192.168.0.0/16"  # Your on-premises network CIDR (required if create_vpn = true)

# ℹ️  NOTE: Worker nodes are in PRIVATE subnets (secure default)
# You'll see a warning in OCI Console about setting up a bastion host.
# This is expected - nodes aren't directly accessible from the internet.
# See README.md "Accessing Worker Nodes" for bastion setup if needed.

# Scaling
node_pool_size = 4

# Multi-AD node placement (high availability within Always Free — zero extra cost)
# OCI regions have 1–3 ADs. Default [0] places all nodes in the first AD.
# Set to [0,1,2] to spread nodes across all three ADs for higher resilience.
# ⚠️  CRITICAL: If your region only has 1 Availability Domain (e.g. ap-singapore-1),
# you MUST set this to [0] to avoid "Invalid index" errors during terraform plan/apply.
# ⚠️  Changing this after first apply triggers a rolling node replacement.
# node_placement_ads = [0]

# SSH access to worker nodes (optional)
# Provide an OpenSSH public key to enable direct SSH to nodes via Bastion/VPN.
# ⚠️  Setting or changing this after first apply triggers a node pool update.
# ssh_public_key = "ssh-rsa AAAA..."

# OCI Load Balancer (public ingress for Kubernetes workloads)
# Always Free: 1 flexible Network LB (Layer 4) AND 1 flexible Application LB (Layer 7, 10 Mbps) per tenancy
create_network_load_balancer     = false # Set to true for Layer 4 NLB (Always Free)
create_application_load_balancer = false # Set to true for Layer 7 ALB (Always Free, 10 Mbps)
# lb_backend_port       = 30080     # HTTP NodePort on worker nodes (default: 30080)
# lb_backend_port_https = 30443     # HTTPS NodePort on worker nodes (default: 30443)

# Ingress Controller (Traefik, installed via Helm)
install_ingress_controller = false # Set to true to install Traefik (requires a load balancer)

# DB System (MySQL HeatWave)
create_mysql_heatwave = false # Set to true to create OCI Always Free MySQL HeatWave DB System and Cluster
# mysql_admin_username  = "admin" # Admin username for MySQL

# Autonomous Database (ATP — Always Free: up to 2 instances, 20 GB each)
create_autonomous_database = false # Set to true to create OCI Always Free ATP Autonomous Database
# autonomous_database_db_name = "appdb"  # Database name (alphanumeric, 14 chars max)
